---
import type { GroupStanding } from "../data/tournament";
import { teams } from "../data/tournament";

interface Props {
  groupName: string;
  standings: GroupStanding[];
}

const { groupName, standings } = Astro.props;
---

<div class="group-card">
  <div class="group-header">
    <h3 class="font-display group-title">{groupName}</h3>
    <div class="group-badge">4 TIMES</div>
  </div>

  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th class="th-pos">#</th>
          <th class="th-team">TIME</th>
          <th class="th-stat">J</th>
          <th class="th-stat">V</th>
          <th class="th-stat">E</th>
          <th class="th-stat">D</th>
          <th class="th-stat hide-mobile">GP</th>
          <th class="th-stat hide-mobile">GC</th>
          <th class="th-stat">SG</th>
          <th class="th-stat th-pts">PTS</th>
        </tr>
      </thead>
      <tbody>
        {standings.map((s, i) => {
          const team = teams[s.team];
          const isQualified = i < 2;
          return (
            <tr class:list={["table-row", { qualified: isQualified }]}>
              <td class="td-pos">
                <span class:list={["pos-badge", { "pos-qualified": isQualified }]}>
                  {i + 1}
                </span>
              </td>
              <td class="td-team">
                <span class="team-flag">{team.flag}</span>
                <span class="team-name">{team.name}</span>
                <span class="team-short">{team.short}</span>
              </td>
              <td class="td-stat">{s.played}</td>
              <td class="td-stat">{s.won}</td>
              <td class="td-stat">{s.drawn}</td>
              <td class="td-stat">{s.lost}</td>
              <td class="td-stat hide-mobile">{s.goalsFor}</td>
              <td class="td-stat hide-mobile">{s.goalsAgainst}</td>
              <td class="td-stat">{s.goalsFor - s.goalsAgainst}</td>
              <td class="td-stat td-pts">{s.points}</td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>

  <div class="group-legend">
    <span class="legend-dot"></span>
    <span class="legend-text">Classificado para o mata-mata</span>
  </div>
</div>

<style>
  .group-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
  }

  .group-header {
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--border-color);
    background-color: var(--bg-secondary);
  }

  .group-title {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-primary);
  }

  .group-badge {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--accent-gold);
    background-color: rgba(212, 168, 67, 0.1);
    padding: 0.25rem 0.625rem;
    border-radius: 4px;
    border: 1px solid rgba(212, 168, 67, 0.2);
  }

  .table-wrapper {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  thead tr {
    border-bottom: 1px solid var(--border-color);
  }

  th {
    font-family: "Oswald", sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    text-transform: uppercase;
    padding: 0.625rem 0.5rem;
    text-align: center;
  }

  .th-pos {
    width: 40px;
  }

  .th-team {
    text-align: left;
    padding-left: 1rem;
  }

  .th-stat {
    width: 40px;
  }

  .th-pts {
    width: 48px;
  }

  .table-row {
    border-bottom: 1px solid rgba(42, 42, 42, 0.5);
    transition: background-color 0.15s ease;
  }

  .table-row:hover {
    background-color: var(--bg-card-hover);
  }

  .table-row:last-child {
    border-bottom: none;
  }

  .qualified {
    border-left: 2px solid var(--accent-gold);
  }

  td {
    padding: 0.75rem 0.5rem;
    font-size: 0.875rem;
    text-align: center;
  }

  .td-pos {
    width: 40px;
  }

  .pos-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 6px;
    background-color: rgba(255, 255, 255, 0.05);
    color: var(--text-secondary);
  }

  .pos-qualified {
    background-color: rgba(212, 168, 67, 0.15);
    color: var(--accent-gold);
  }

  .td-team {
    text-align: left;
    padding-left: 1rem;
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .team-flag {
    font-size: 1.25rem;
  }

  .team-name {
    font-weight: 500;
    color: var(--text-primary);
  }

  .team-short {
    display: none;
    font-weight: 500;
    color: var(--text-primary);
  }

  .td-stat {
    color: var(--text-secondary);
    font-variant-numeric: tabular-nums;
  }

  .td-pts {
    font-weight: 700;
    color: var(--text-primary);
    font-size: 0.9375rem;
  }

  .group-legend {
    padding: 0.625rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-top: 1px solid var(--border-color);
  }

  .legend-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--accent-gold);
  }

  .legend-text {
    font-size: 0.6875rem;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .hide-mobile {
      display: none;
    }
    .team-name {
      display: none;
    }
    .team-short {
      display: inline;
    }
    th, td {
      padding: 0.5rem 0.25rem;
      font-size: 0.75rem;
    }
  }
</style>
